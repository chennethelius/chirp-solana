{
  "cli": {
    "version": ">= 3.12.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_CHIRP_RELAY_URL": "https://YOUR-NGROK-OR-DEPLOY-URL.example",
        "EXPO_PUBLIC_CHIRP_MODE": "audio",
        "EXPO_PUBLIC_CHIRP_CHANNEL": "demo"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
